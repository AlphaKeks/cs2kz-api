  "query": "SELECT\n\t\t   id AS `id: FilterId`,\n\t\t   nub_tier AS `nub_tier: Tier`,\n\t\t   pro_tier AS `pro_tier: Tier`\n\t\t FROM Filters\n\t\t WHERE id = (\n\t\t   SELECT id\n\t\t   FROM FiltersToRecalculate\n\t\t   WHERE priority != 0\n\t\t   ORDER BY priority DESC\n\t\t   LIMIT 1\n\t\t )",
